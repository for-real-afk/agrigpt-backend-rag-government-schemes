# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here

# ── Gemini API keys (rotate through all when free-tier quota is hit) ──────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_key_here
GEMINI_API_KEY_3=your_third_gemini_key_here

# ── Gemini model (default: gemini-2.0-flash) ──────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash

# ── Groq fallback (free: 14,400 req/day — https://console.groq.com) ──────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
